{
  "_comment": "Canonical hook→registration map. `scripts/install.mjs` reads this, and for each hook the user selects (whose .mjs exists in hooks/), merges its entries into ~/.claude/settings.json. command is derived as `node ~/.claude/hooks/<name>.mjs`. A hook with multiple entries registers on multiple events (e.g. tests-must-pass on PostToolUse+Stop). Tiers mirror the README.",

  "tier1_standalone": {
    "block-dangerous-commands": [{ "event": "PreToolUse", "matcher": "Bash", "timeout": 5 }],
    "protect-secrets":          [{ "event": "PreToolUse", "matcher": "Read|Edit|Write|Bash", "timeout": 5 }],
    "no-commit-to-main":        [{ "event": "PreToolUse", "matcher": "Bash", "timeout": 5 }],
    "read-before-write":        [{ "event": "PreToolUse", "matcher": "Edit|MultiEdit", "timeout": 5 }],
    "pixels-only-proof":        [{ "event": "Stop", "timeout": 5 }],
    "tests-must-pass":          [{ "event": "PostToolUse", "matcher": "Bash", "timeout": 5 }, { "event": "Stop", "timeout": 5 }],
    "name-by-use":              [{ "event": "PreToolUse", "matcher": "Write|Edit|MultiEdit", "timeout": 5 }],
    "filename-quality-guard":   [{ "event": "PreToolUse", "matcher": "Write", "timeout": 5 }],
    "no-write-to-main":         [{ "event": "PreToolUse", "matcher": "Bash", "timeout": 5 }],
    "delete-merged-branches":   [{ "event": "PostToolUse", "matcher": "Bash|PowerShell", "timeout": 5 }],
    "no-junk-files":            [{ "event": "Stop", "timeout": 5 }],
    "never-idle":               [{ "event": "Stop", "timeout": 5 }],
    "compass-line-guard":       [{ "event": "Stop", "timeout": 5 }],
    "husky-on-new-projects":    [{ "event": "SessionStart", "timeout": 5 }],
    "rebuild-after-commit":     [{ "event": "Stop", "timeout": 5 }],
    "stamp-build-fingerprint":  [{ "event": "PostToolUse", "matcher": "Bash", "timeout": 5 }]
  },

  "tier2_memory": {
    "learnings-toc-inject":     [{ "event": "SessionStart", "timeout": 5 }],
    "learnings-error-match":    [{ "event": "PostToolUse", "matcher": "Bash|Edit|Write|MultiEdit", "timeout": 5 }],
    "require-learnings-ack":    [{ "event": "PreToolUse", "matcher": "Edit|Write|MultiEdit|Read", "timeout": 5 }],
    "learnings-write-nudge":    [{ "event": "PostToolUse", "matcher": "Bash", "timeout": 5 }, { "event": "Stop", "timeout": 5 }],
    "handoff-continuity":       [{ "event": "Stop", "timeout": 5 }]
  },

  "tier3_opinionated": {
    "no-backcompat":             [{ "event": "PreToolUse", "matcher": "Write|Edit|MultiEdit", "timeout": 5 }, { "event": "Stop", "timeout": 5 }],
    "root-cause-first":         [{ "event": "PreToolUse", "matcher": "Write|Edit|MultiEdit", "timeout": 5 }],
    "decay-footer":             [{ "event": "Stop", "timeout": 5 }],
    "hookbook-sync":            [{ "event": "Stop", "timeout": 5 }],
    "discipline-sync":          [{ "event": "Stop", "timeout": 5 }],
    "never-stop-asking":        [{ "event": "Stop", "timeout": 5 }],
    "recommend-when-listing":   [{ "event": "Stop", "timeout": 5 }],
    "file-size-guard":          [{ "event": "PostToolUse", "matcher": "Write", "timeout": 5 }],
    "e2e-or-its-theatre":       [{ "event": "Stop", "timeout": 5 }],
    "owed-live-gate-reminder":  [{ "event": "UserPromptSubmit", "timeout": 5 }],
    "no-bullshit-tests":        [{ "event": "PreToolUse", "matcher": "Write|Edit|MultiEdit", "timeout": 5 }],
    "docs-on-feature-commit":   [{ "event": "PostToolUse", "matcher": "Bash", "timeout": 5 }, { "event": "Stop", "timeout": 5 }]
  }
}
